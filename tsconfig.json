{
  "extends": "adonis-preset-ts/tsconfig.json",

  "compilerOptions": {
    "outDir": "build",
    "rootDir": "./",

    "baseUrl": "./",

    "sourceMap": true,

    "skipLibCheck": true,

    "strict": true,

    "paths": {
      "App/*": ["./app/*"],
      "Config/*": ["./config/*"],
      "Contracts/*": ["./contracts/*"],
      "Database/*": ["./database/*"]
    },

    "types": [
      "@adonisjs/core",
      "@adonisjs/repl",
      "@japa/preset-adonis/build/adonis-typings",
      "@adonisjs/lucid"
    ]
  },

  "include": [
    "app/**/*",
    "start/**/*",
    "config/**/*",
    "database/**/*",
    "contracts/**/*"
  ],

  "exclude": [
    "node_modules",
    "build"
  ]
}

